{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jentlememes-installer",
  "version": "1.0.5-beta.1",
  "identifier": "com.jentleproject.jentlememes-installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "JentleMemes Launcher — Установка",
        "width": 620,
        "height": 440,
        "resizable": false,
        "decorations": false,
        "center": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
