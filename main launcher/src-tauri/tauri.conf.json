{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jentlememes-launcher",
  "version": "1.0.2-beta",
  "identifier": "com.jentleproject.jentlememes-launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "jentlememes-launcher",
        "width": 800,
        "height": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; img-src 'self' http://asset.localhost https: data: blob:; connect-src 'self' https: http:; font-src 'self' data:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libgtk-3-0", "libwebkit2gtk-4.1-0", "libayatana-appindicator3-1"]
      },
      "appimage": {
        "bundleMediaFramework": false
      },
      "rpm": {
        "depends": ["gtk3", "webkit2gtk4.1", "libayatana-appindicator-gtk3"]
      }
    },
    "category": "Game",
    "shortDescription": "JentleMemes Minecraft Launcher"
  }
}
